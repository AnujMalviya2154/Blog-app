
<%- include('partials/header') %>
<div class="container-narrow">
  <div class="page-header">
    <h1>Edit Post</h1>
    <p>Update your ideas.</p>
  </div>

  <div class="form-card">
    <form action="/edit/<%= post.id %>" method="POST">
      <div class="form-group">
        <label for="postTitle">Title</label>
        <input type="text" class="form-input" id="postTitle" name="postTitle" value="<%= post.title %>" required>
      </div>

      <div class="form-group">
        <label for="postContent">Content</label>
        <textarea class="form-textarea" id="postContent" name="postContent" required><%= post.content %></textarea>
      </div>

      <div class="form-actions" style="justify-content: flex-end;">
        <a href="/posts/<%= post.id %>" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary btn-lg">Update Post</button>
      </div>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
